<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>真珠美人魚：海洋守護者學習網</title>
    <style>
        /* =========================================
           CSS 樣式區：共用與導覽列
           ========================================= */
        body {
            margin: 0;
            padding: 0;
            font-family: 'Microsoft JhengHei', sans-serif;
            background-color: #e0f7fa;
            overflow-x: hidden;
        }

        /* 頂部導覽列 */
        nav {
            background-color: rgba(255, 105, 180, 0.9);
            height: 60px;
            display: flex;
            justify-content: center;
            align-items: center;
            position: fixed;
            top: 0;
            width: 100%;
            z-index: 100;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        nav button {
            background: none;
            border: 2px solid white;
            color: white;
            font-size: 16px;
            font-weight: bold;
            padding: 8px 15px;
            margin: 0 10px;
            border-radius: 20px;
            cursor: pointer;
            transition: all 0.3s;
        }

        nav button:hover, nav button.active {
            background-color: white;
            color: #ff69b4;
        }

        /* 分頁隱藏與顯示機制 */
        .page {
            display: none;
            padding-top: 60px; /* 避開固定在頂部的導覽列 */
            min-height: calc(100vh - 60px);
        }
        .page.active {
            display: block;
        }

        /* =========================================
           分頁 1：遊戲區
           ========================================= */
        #page-game {
            position: relative;
            background: 
                linear-gradient(rgba(255, 255, 255, 0.2) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 255, 255, 0.2) 1px, transparent 1px),
                linear-gradient(to bottom, #4facfe 0%, #00f2fe 100%);
            background-size: 60px 60px, 60px 60px, 100% 100%;
            overflow: hidden;
        }
        
        /* 計時器與計分板 */
        #timer-board {
            position: absolute;
            top: 20px;
            left: 20px;
            font-size: 24px;
            font-weight: bold;
            color: white;
            background-color: rgba(0, 191, 255, 0.9);
            padding: 10px 20px;
            border-radius: 20px;
            z-index: 10;
        }
        #score-board {
            position: absolute;
            top: 20px;
            right: 20px;
            font-size: 24px;
            font-weight: bold;
            color: white;
            background-color: rgba(255, 105, 180, 0.9);
            padding: 10px 20px;
            border-radius: 20px;
            z-index: 10;
        }

        /* 遊戲準備/結束遮罩層 */
        .game-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0, 0, 0, 0.7);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 20;
            color: white;
        }
        .game-overlay h2 { font-size: 48px; color: #ff69b4; text-shadow: 2px 2px white; margin-bottom: 20px; }
        .game-overlay p { font-size: 24px; margin-bottom: 30px; }
        .game-overlay button {
            font-size: 24px; padding: 15px 40px; border-radius: 30px; border: none;
            background-color: #ff69b4; color: white; cursor: pointer; font-weight: bold;
            box-shadow: 0 4px 6px rgba(0,0,0,0.3); transition: 0.2s;
        }
        .game-overlay button:hover { transform: scale(1.1); background-color: #ff1493; }

        /* 遊戲物件樣式 */
        .game-object {
            position: absolute;
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 40px;
            transition: left 0.1s, top 0.1s;
            z-index: 5;
        }
        #lucia { z-index: 6; filter: drop-shadow(0 0 10px #ff69b4); }
        
        /* 動畫效果 */
        .glow { animation: flash 0.3s; }
        @keyframes flash {
            0% { filter: drop-shadow(0 0 20px #fff); transform: scale(1.2); }
            100% { filter: drop-shadow(0 0 10px #ff69b4); transform: scale(1); }
        }
        .singing { animation: pearlVoice 0.5s ease-in-out; }
        @keyframes pearlVoice {
            0% { transform: scale(1) rotate(0deg); filter: drop-shadow(0 0 10px #ff69b4); }
            50% { transform: scale(1.3) rotate(15deg); filter: drop-shadow(0 0 40px #fff); }
            100% { transform: scale(1) rotate(0deg); filter: drop-shadow(0 0 10px #ff69b4); }
        }
        .trash { animation: float 2s infinite ease-in-out; }
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-8px); }
        }

        /* =========================================
           分頁 2：浮力實驗區
           ========================================= */
        .content-container { max-width: 800px; margin: 0 auto; padding: 30px 20px; }
        .experiment-box { display: flex; background: white; border-radius: 20px; padding: 20px; box-shadow: 0 10px 20px rgba(0,0,0,0.1); gap: 20px; }
        .controls { flex: 1; display: flex; flex-direction: column; gap: 20px; }
        .slider-group label { font-size: 18px; font-weight: bold; color: #0277bd; }
        .slider-group input { width: 100%; margin-top: 10px; }
        .water-tank { width: 300px; height: 400px; background: linear-gradient(to bottom, #81d4fa, #0288d1); border: 4px solid #01579b; border-radius: 10px; position: relative; overflow: hidden; }
        #diver-lucia { position: absolute; font-size: 60px; left: 50%; transform: translateX(-50%); top: 170px; transition: top 1s ease-in-out; filter: drop-shadow(2px 2px 5px rgba(0,0,0,0.3)); }

        /* =========================================
           分頁 3：海洋知識區
           ========================================= */
        .knowledge-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-top: 20px; }
        .card { background: white; padding: 20px; border-radius: 15px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); text-align: center; }
        .card h3 { color: #ff69b4; margin-top: 10px; }
        .card p { color: #555; line-height: 1.6; text-align: left; }
        .emoji-big { font-size: 50px; }

        /* =========================================
           分頁 4：測驗評量區
           ========================================= */
        .quiz-container { background: white; padding: 30px; border-radius: 20px; box-shadow: 0 10px 20px rgba(0,0,0,0.1); }
        .question { font-size: 20px; font-weight: bold; color: #333; margin-bottom: 20px; }
        .options { display: flex; flex-direction: column; gap: 10px; }
        .option-btn { padding: 15px; font-size: 16px; background: #f0f0f0; border: 2px solid #ddd; border-radius: 10px; cursor: pointer; transition: 0.2s; text-align: left; }
        .option-btn:hover { background: #e1bee7; border-color: #ab47bc; }
        .option-btn.correct { background: #c8e6c9; border-color: #4caf50; color: #2e7d32; }
        .option-btn.wrong { background: #ffcdd2; border-color: #f44336; color: #c62828; }
        #quiz-result { margin-top: 20px; font-size: 18px; font-weight: bold; color: #ff69b4; }
        .action-btn { margin-top: 20px; padding: 10px 20px; color: white; border: none; border-radius: 10px; cursor: pointer; font-size: 16px; display: none; }
        #next-btn { background: #ff69b4; }
        #restart-quiz-btn { background: #00bfdf; }
    </style>
</head>
<body>

    <!-- 頂部導覽列 -->
    <nav>
        <button class="nav-btn active" onclick="switchTab('page-game', this)">🎮 清理任務</button>
        <button class="nav-btn" onclick="switchTab('page-experiment', this)">🔬 浮力實驗</button>
        <button class="nav-btn" onclick="switchTab('page-knowledge', this)">📖 海洋知識</button>
        <button class="nav-btn" onclick="switchTab('page-quiz', this)">📝 知識大挑戰</button>
    </nav>

    <!-- 第 1 頁：遊戲區 -->
    <div id="page-game" class="page active">
        <div id="timer-board">時間：<span id="timer">60</span> 秒</div>
        <div id="score-board">分數：<span id="score">0</span></div>
        <div id="lucia" class="game-object">🧜‍♀️</div>
        
        <div id="game-overlay" class="game-overlay">
            <h2 id="overlay-title">準備好清理海洋了嗎？</h2>
            <p id="overlay-desc">每位同學限時 1 分鐘，比賽看誰的分數最高！</p>
            <button onclick="startGame()">開始遊戲</button>
        </div>
    </div>

    <!-- 第 2 頁：浮力實驗區 -->
    <div id="page-experiment" class="page">
        <div class="content-container">
            <h2 style="color: #0277bd; text-align: center;">🔬 露亞的潛水浮力實驗</h2>
            <p style="text-align: center; color: #555;">小朋友，拉動下面的拉桿，看看「重量」和「浮力」會怎麼影響露亞在水中的位置！</p>
            <div class="experiment-box">
                <div class="controls">
                    <div class="slider-group">
                        <label>露亞的重量 (往下沉的力)：<span id="weight-val">5</span></label>
                        <input type="range" id="weight-slider" min="1" max="10" value="5">
                    </div>
                    <div class="slider-group">
                        <label>海水的浮力 (往上推的力)：<span id="buoyancy-val">5</span></label>
                        <input type="range" id="buoyancy-slider" min="1" max="10" value="5">
                    </div>
                    <div style="margin-top: 20px; padding: 15px; background: #fff9c4; border-radius: 10px;">
                        <strong>💡 小知識：</strong><br>
                        <span id="experiment-result">目前重量和浮力一樣大，露亞懸浮在水中！</span>
                    </div>
                </div>
                <div class="water-tank">
                    <div id="diver-lucia">🧜‍♀️</div>
                </div>
            </div>
        </div>
    </div>

    <!-- 第 3 頁：海洋知識區 -->
    <div id="page-knowledge" class="page">
        <div class="content-container">
            <h2 style="color: #0277bd; text-align: center;">📖 認識海洋垃圾</h2>
            <div class="knowledge-grid">
                <div class="card"><div class="emoji-big">🛍️</div><h3>塑膠袋的陷阱</h3><p>飄在海裡的塑膠袋，看起來就像是半透明的水母。最喜歡吃水母的海龜，常常會不小心把它們吃下肚喔！</p></div>
                <div class="card"><div class="emoji-big">🥤</div><h3>微塑膠危機</h3><p>塑膠在海裡泡久了會碎裂成「微塑膠」。小魚吃下微塑膠，最後可能又會被人類吃進肚子裡！</p></div>
                <div class="card"><div class="emoji-big">🪫</div><h3>有毒的廢電池</h3><p>電池掉進海裡，裡面的重金屬會流出來，這就像是在海水裡倒毒藥一樣，會讓海洋生物生病。</p></div>
            </div>
        </div>
    </div>

    <!-- 第 4 頁：測驗評量區 -->
    <div id="page-quiz" class="page">
        <div class="content-container">
            <h2 style="color: #0277bd; text-align: center;">📝 海洋守護者小測驗</h2>
            <div class="quiz-container">
                <div id="question-text" class="question">準備好挑戰了嗎？</div>
                <div id="options-container" class="options"></div>
                <div id="quiz-result"></div>
                <button id="next-btn" class="action-btn" onclick="nextQuestion()">下一題</button>
                <button id="restart-quiz-btn" class="action-btn" onclick="initQuiz()">🔄 再挑戰一次</button>
            </div>
        </div>
    </div>

    <!-- ======================================================= -->
    <!-- JavaScript 邏輯區 -->
    <!-- ======================================================= -->
    <script>
        /* ----------------------------------------------------
           功能 1：分頁切換
           ---------------------------------------------------- */
        function switchTab(pageId, btnElement) {
            document.querySelectorAll('.page').forEach(page => page.classList.remove('active'));
            document.querySelectorAll('.nav-btn').forEach(btn => btn.classList.remove('active'));
            document.getElementById(pageId).classList.add('active');
            btnElement.classList.add('active');
        }

        /* ----------------------------------------------------
           功能 2：遊戲區核心邏輯
           ---------------------------------------------------- */
        const gameContainer = document.getElementById('page-game');
        const step = 60; // 每個格子的寬度/高度
        let score = 0;
        const scoreElement = document.getElementById('score');
        const luciaElement = document.getElementById('lucia');
        let luciaPos = { x: 0, y: 0 };
        let trashItems = []; 
        const trashEmojis = ['🥤', '🥫', '🛍️', '🪫', '🥡'];

        let timeLeft = 60;
        let timerInterval;
        let isGameRunning = false;
        const timerElement = document.getElementById('timer');
        const gameOverlay = document.getElementById('game-overlay');
        const overlayTitle = document.getElementById('overlay-title');
        const overlayDesc = document.getElementById('overlay-desc');

        // 開始遊戲按鈕觸發
        function startGame() {
            gameOverlay.style.display = 'none';
            score = 0;
            scoreElement.innerText = score;
            timeLeft = 60;
            timerElement.innerText = timeLeft;
            isGameRunning = true;

            // 清除上一場的舊垃圾
            trashItems.forEach(t => t.element.remove());
            trashItems = [];

            // 把露亞移回中間
            const w = gameContainer.clientWidth;
            const h = gameContainer.clientHeight;
            luciaPos.x = Math.floor((w / 2) / step) * step;
            luciaPos.y = Math.floor((h / 2) / step) * step;
            updateLuciaPosition();

            // 產生 3 個新垃圾
            for(let i=0; i<3; i++) {
                spawnTrash();
            }

            // 開始倒數計時
            timerInterval = setInterval(() => {
                timeLeft--;
                timerElement.innerText = timeLeft;
                if (timeLeft <= 0) {
                    endGame();
                }
            }, 1000);
        }

        // 結束遊戲
        function endGame() {
            clearInterval(timerInterval);
            isGameRunning = false;
            gameOverlay.style.display = 'flex';
            overlayTitle.innerText = "時間到！";
            overlayDesc.innerText = `太棒了！你總共撿了 ${score} 個海洋垃圾！`;
            gameOverlay.querySelector('button').innerText = "再玩一次";
        }

        // 更新露亞的畫面位置
        function updateLuciaPosition() {
            luciaElement.style.left = luciaPos.x + 'px';
            luciaElement.style.top = luciaPos.y + 'px';
        }

        // 產生一個新的垃圾
        function spawnTrash() {
            const w = gameContainer.clientWidth;
            const h = gameContainer.clientHeight;
            // 確保有足夠的格子，並避免超過邊界
            const maxCols = Math.max(1, Math.floor((w - step) / step));
            const maxRows = Math.max(1, Math.floor((h - step) / step));

            const randomX = Math.floor(Math.random() * maxCols) * step;
            const randomY = Math.floor(Math.random() * maxRows) * step;

            const trashEl = document.createElement('div');
            trashEl.classList.add('game-object', 'trash');
            trashEl.innerText = trashEmojis[Math.floor(Math.random() * trashEmojis.length)];
            trashEl.style.left = randomX + 'px';
            trashEl.style.top = randomY + 'px';

            gameContainer.appendChild(trashEl);
            trashItems.push({ x: randomX, y: randomY, element: trashEl });
        }

        // 檢查有沒有撿到垃圾
        function checkCollision() {
            for (let i = 0; i < trashItems.length; i++) {
                let trash = trashItems[i];
                
                // 如果露亞的座標跟垃圾完全一樣
                if (luciaPos.x === trash.x && luciaPos.y === trash.y) {
                    // 1. 加分
                    score += 1;
                    scoreElement.innerText = score;
                    
                    // 2. 播放發光特效
                    luciaElement.classList.add('glow');
                    setTimeout(() => luciaElement.classList.remove('glow'), 300);
                    
                    // 3. 把垃圾從畫面上跟陣列裡刪除
                    trash.element.remove();
                    trashItems.splice(i, 1);
                    
                    // 4. 生出一個新的垃圾 (自動出現新垃圾)
                    spawnTrash();
                    
                    break; // 一次只會撿一個，撿到了就跳出迴圈
                }
            }
        }

        // 鍵盤操控邏輯
        document.addEventListener('keydown', function(event) {
            // 不在遊戲頁面，或遊戲沒在進行時，不能移動
            if (!gameContainer.classList.contains('active')) return;
            if (!isGameRunning) return;

            // 空白鍵魔法
            if (event.code === 'Space') {
                event.preventDefault();
                luciaElement.classList.add('singing');
                setTimeout(() => luciaElement.classList.remove('singing'), 500);
                return;
            }

            const w = gameContainer.clientWidth;
            const h = gameContainer.clientHeight;
            const maxX = Math.max(0, Math.floor((w - step) / step) * step);
            const maxY = Math.max(0, Math.floor((h - step) / step) * step);
            let moved = false;

            if (event.key === 'ArrowUp') { luciaPos.y -= step; moved = true; }
            else if (event.key === 'ArrowDown') { luciaPos.y += step; moved = true; }
            else if (event.key === 'ArrowLeft') { luciaPos.x -= step; luciaElement.style.transform = 'scaleX(-1)'; moved = true; }
            else if (event.key === 'ArrowRight') { luciaPos.x += step; luciaElement.style.transform = 'scaleX(1)'; moved = true; }

            if (moved) {
                event.preventDefault(); // 防止畫面跟著上下捲動
                // 邊界檢查
                if (luciaPos.x < 0) luciaPos.x = 0;
                if (luciaPos.x > maxX) luciaPos.x = maxX;
                if (luciaPos.y < 0) luciaPos.y = 0;
                if (luciaPos.y > maxY) luciaPos.y = maxY;

                // 更新位置後，呼叫「檢查碰撞」，垃圾才會重新產生
                updateLuciaPosition();
                checkCollision(); 
            }
        });


        /* ----------------------------------------------------
           功能 3：浮力實驗邏輯
           ---------------------------------------------------- */
        const weightSlider = document.getElementById('weight-slider');
        const buoyancySlider = document.getElementById('buoyancy-slider');
        const diverLucia = document.getElementById('diver-lucia');
        const expResultText = document.getElementById('experiment-result');

        function updateExperiment() {
            const weight = parseInt(weightSlider.value);
            const buoyancy = parseInt(buoyancySlider.value);
            document.getElementById('weight-val').innerText = weight;
            document.getElementById('buoyancy-val').innerText = buoyancy;

            let newTop = 170;
            if (weight > buoyancy) {
                newTop = 170 + ((weight - buoyancy) * 30);
                if (newTop > 320) newTop = 320;
                expResultText.innerHTML = "因為 <strong>重量 > 浮力</strong>，所以露亞往下沉了！";
                expResultText.style.color = "#c62828";
            } else if (weight < buoyancy) {
                newTop = 170 - ((buoyancy - weight) * 30);
                if (newTop < 10) newTop = 10;
                expResultText.innerHTML = "因為 <strong>浮力 > 重量</strong>，所以露亞往上浮了！";
                expResultText.style.color = "#2e7d32";
            } else {
                newTop = 170;
                expResultText.innerHTML = "重量和浮力一樣大 (<strong>重量 = 浮力</strong>)，露亞完美的停在水中！";
                expResultText.style.color = "#0277bd";
            }
            diverLucia.style.top = newTop + 'px';
        }
        weightSlider.addEventListener('input', updateExperiment);
        buoyancySlider.addEventListener('input', updateExperiment);


        /* ----------------------------------------------------
           功能 4：測驗評量邏輯 (隨機抽題不重複升級版)
           ---------------------------------------------------- */
        // 建立完整的大題庫 (移除原有的文字題號，改由程式自動編號)
        const quizBank = [
            { question: "海龜常常會誤食哪一種海洋垃圾，因為它看起來很像水母？", options: ["鋁罐", "塑膠袋", "廢棄電池", "玻璃瓶"], answer: 1 },
            { question: "在剛才的浮力實驗中，如果物體的「重量」大於海水的「浮力」，物體會發生什麼事？", options: ["往上浮出水面", "停在水中央不動", "往下沉到底部", "會變形"], answer: 2 },
            { question: "為什麼電池掉進海裡特別危險？", options: ["會讓海水變熱", "重金屬流出會毒害海洋生物", "會發出強光", "會把海水吸乾"], answer: 1 },
            { question: "下列哪一種行為可以幫助減少海洋垃圾？", options: ["去海邊玩不帶走垃圾", "把垃圾丟進水溝", "多用一次性塑膠杯", "出門自備環保餐具和水壺"], answer: 3 },
            { question: "海洋裡的「微塑膠」主要是從哪裡來的？", options: ["大自然本來就有的", "大塊塑膠垃圾在海裡碎裂變成", "魚類吐出來的泡泡", "海底火山噴發"], answer: 1 },
            { question: "真珠美人魚主角「露亞」的真珠是哪一種顏色的呢？", options: ["粉紅色", "水藍色", "碧色", "紫色"], answer: 0 }
        ];

        let selectedQuestions = []; // 每次測驗被隨機抽出的題目
        let currentQuizIndex = 0;
        let quizScore = 0;

        // 初始化測驗：洗牌並抽出指定數量的題目
        function initQuiz() {
            // 複製題庫並隨機洗牌，然後抽出前 3 題 (保證這 3 題不重複)
            selectedQuestions = [...quizBank].sort(() => 0.5 - Math.random()).slice(0, 3);
            
            currentQuizIndex = 0;
            quizScore = 0;
            document.getElementById('restart-quiz-btn').style.display = 'none'; // 隱藏再挑戰按鈕
            loadQuiz();
        }

        // 載入當前題目
        function loadQuiz() {
            const qData = selectedQuestions[currentQuizIndex];
            // 動態加上題號
            document.getElementById('question-text').innerText = `第 ${currentQuizIndex + 1} 題：${qData.question}`;
            
            const optionsContainer = document.getElementById('options-container');
            optionsContainer.innerHTML = ''; 
            document.getElementById('quiz-result').innerText = '';
            document.getElementById('next-btn').style.display = 'none';

            qData.options.forEach((opt, index) => {
                const btn = document.createElement('button');
                btn.className = 'option-btn';
                btn.innerText = opt;
                btn.onclick = () => checkAnswer(index, btn);
                optionsContainer.appendChild(btn);
            });
        }

        // 檢查答案
        function checkAnswer(selectedIndex, btnElement) {
            const correctIndex = selectedQuestions[currentQuizIndex].answer;
            const optionsBtns = document.querySelectorAll('.option-btn');
            optionsBtns.forEach(btn => btn.onclick = null); // 鎖定作答

            if (selectedIndex === correctIndex) {
                btnElement.classList.add('correct');
                document.getElementById('quiz-result').innerText = "🎉 答對囉！你真棒！";
                quizScore++;
            } else {
                btnElement.classList.add('wrong');
                optionsBtns[correctIndex].classList.add('correct');
                document.getElementById('quiz-result').innerText = "❌ 答錯了，請看綠色的正確答案喔！";
            }
            document.getElementById('next-btn').style.display = 'block';
        }

        // 下一題或結算
        function nextQuestion() {
            currentQuizIndex++;
            if (currentQuizIndex < selectedQuestions.length) {
                loadQuiz();
            } else {
                // 測驗結束畫面
                document.getElementById('question-text').innerText = "測驗結束！";
                document.getElementById('options-container').innerHTML = "";
                document.getElementById('next-btn').style.display = 'none';
                document.getElementById('quiz-result').innerText = `總結：你答對了 ${quizScore} / ${selectedQuestions.length} 題！你是超棒的海洋守護者！`;
                
                // 顯示再挑戰一次按鈕
                document.getElementById('restart-quiz-btn').style.display = 'inline-block';
            }
        }

        // 確保網頁載入後啟動測驗初始化
        window.addEventListener('load', () => {
            initQuiz();
        });

    </script>
</body>
</html>
